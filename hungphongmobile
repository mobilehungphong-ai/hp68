    // Discount trigger
    function applyDiscount() {
      if (isHoldQuoteTicket) {
        showCustomAlert("Lưu ý", "Máy đang ở chế độ chờ báo giá sau, không cần áp dụng chiết khấu lúc này.", "warning");
        return;
      }
      const pct = parseFloat(document.getElementById('discount-percent').value) || 0;
      const cash = parseFloat(document.getElementById('discount-cash').value) || 0;

      if (pct > 0 && cash > 0) {
        showCustomAlert("Lỗi lựa chọn", "Chỉ chọn chiết khấu theo % HOẶC theo Số tiền mặt cụ thể.", "warning");
        return;
      }

      discountPercent = pct;
      discountCash = cash;

      updateLiveReceipt();
      closeModal('discount-modal');
      triggerToast("Đã cập nhật chiết khấu đơn");
    }

    // Promo triggers
    function applyPromo() {
      if (isHoldQuoteTicket) {
        showCustomAlert("Lưu ý", "Máy đang ở chế độ chờ báo giá sau, không thể áp dụng khuyến mại lúc này.", "warning");
        return;
      }
      const code = document.getElementById('promo-code-input').value.trim().toUpperCase();
      validateAndApplyPromo(code);
    }

    function selectQuickPromo(code) {
      if (isHoldQuoteTicket) {
        showCustomAlert("Lưu ý", "Máy đang ở chế độ chờ báo giá sau, không thể áp dụng khuyến mại lúc này.", "warning");
        return;
      }
      validateAndApplyPromo(code);
    }

    function validateAndApplyPromo(code) {
      if (!code) {
        promoAmount = 0;
        selectedPromoCode = "";
        updateLiveReceipt();
        closeModal('promo-modal');
        return;
      }

      if (code === "TRIAN10") {
        promoAmount = Math.round(subtotalValue * 0.1);
        selectedPromoCode = "TRIAN10";
        triggerToast("Voucher TRIAN10 (-10%) thành công");
      } else if (code === "KHACHQUEN50K") {
        promoAmount = 50000;
        selectedPromoCode = "KHACHQUEN50K";
        triggerToast("Voucher KHACHQUEN50K (-50k) thành công");
      } else {
        showCustomAlert("Mã không tồn tại", "Mã chương trình khuyến mại này chưa có hiệu lực hoặc đã hết hạn.", "warning");
        return;
      }

      updateLiveReceipt();
      closeModal('promo-modal');
    }

