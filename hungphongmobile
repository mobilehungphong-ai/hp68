<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hùng Phong Mobile - Hệ Thống Giao Nhận Máy Sửa Chữa</title>
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Courier+Prime:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
    .font-receipt {
      font-family: 'Courier Prime', monospace;
    }
    /* Style cho bảng in ấn cổ điển */
    .print-table {
      border-left: 1px solid #7a7676;
      border-top: 1px solid #7a7676;
      width: 100%;
    }
    .print-table th, .print-table td {
      border-right: 1px solid #7a7676;
      border-bottom: 1px solid #7a7676;
      padding: 6px 8px;
    }
    /* Tối ưu hóa in ấn khổ A5 dọc */
    @media print {
      @page {
        size: A5 portrait;
        margin: 5mm;
      }
      body * {
        visibility: hidden;
      }
      #print-area, #print-area * {
        visibility: visible;
      }
      #print-area {
        position: absolute;
        left: 0;
        top: 0;
        width: 100%;
        border: none !important;
        box-shadow: none !important;
        background: white !important;
        color: black !important;
        padding: 0 !important;
      }
    }
  </style>
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen flex flex-col">

  <!-- HEADER -->
  <header class="bg-white border-b border-slate-200 sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16 items-center">
        <!-- Hùng Phong Mobile -->
        <div class="flex items-center space-x-3">
          <div class="bg-blue-600 text-white p-2.5 rounded-xl shadow-lg shadow-blue-500/20">
            <i data-lucide="smartphone" class="w-6 h-6"></i>
          </div>
          <div>
            <h1 class="text-xl font-extrabold tracking-tight text-slate-900">HÙNG PHONG MOBILE</h1>
            <p class="text-xs font-semibold text-blue-600 tracking-wide uppercase">Hệ thống Tiếp Nhận & Sửa Chữa</p>
          </div>
        </div>

        <!-- Navigation Tabs -->
        <nav class="hidden md:flex space-x-1 bg-slate-100 p-1.5 rounded-xl">
          <button onclick="switchTab('reception')" id="tab-reception" class="tab-btn px-4 py-2 text-sm font-semibold rounded-lg bg-white text-slate-900 shadow-sm flex items-center space-x-2 transition-all">
            <i data-lucide="plus-circle" class="w-4 h-4 text-blue-600"></i>
            <span>Tiếp Nhận Máy</span>
          </button>
          <button onclick="switchTab('orders')" id="tab-orders" class="tab-btn px-4 py-2 text-sm font-medium rounded-lg text-slate-600 hover:text-slate-900 flex items-center space-x-2 transition-all">
            <i data-lucide="list-todo" class="w-4 h-4"></i>
            <span>Danh Sách Đơn</span>
          </button>
          <button onclick="switchTab('customers')" id="tab-customers" class="tab-btn px-4 py-2 text-sm font-medium rounded-lg text-slate-600 hover:text-slate-900 flex items-center space-x-2 transition-all">
            <i data-lucide="users" class="w-4 h-4"></i>
            <span>Khách Hàng</span>
          </button>
          <button onclick="switchTab('reports')" id="tab-reports" class="tab-btn px-4 py-2 text-sm font-medium rounded-lg text-slate-600 hover:text-slate-900 flex items-center space-x-2 transition-all">
            <i data-lucide="bar-chart-3" class="w-4 h-4"></i>
            <span>Báo Cáo</span>
          </button>
        </nav>

        <!-- Live Clock & User Info -->
        <div class="flex items-center space-x-4">
          <div class="text-right hidden sm:block">
            <div id="live-time" class="text-sm font-bold text-slate-700">00:00:00</div>
            <div class="text-[10px] text-slate-400 font-medium">Nhân viên: HP68</div>
          </div>
          <span class="h-8 w-[1px] bg-slate-200 hidden sm:block"></span>
          <button class="bg-slate-100 hover:bg-slate-200 text-slate-600 p-2 rounded-xl transition-colors">
            <i data-lucide="bell" class="w-5 h-5"></i>
          </button>
        </div>
      </div>
    </div>
  </header>

  <!-- MOBILE NAVIGATION BAR -->
  <div class="md:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-slate-200 px-4 py-2 flex justify-around z-40 shadow-xl">
    <button onclick="switchTab('reception')" class="flex flex-col items-center space-y-1 text-slate-600 active:text-blue-600 py-1">
      <i data-lucide="plus-circle" class="w-5 h-5"></i>
      <span class="text-[10px] font-semibold">Tiếp Nhận</span>
    </button>
    <button onclick="switchTab('orders')" class="flex flex-col items-center space-y-1 text-slate-600 active:text-blue-600 py-1">
      <i data-lucide="list-todo" class="w-5 h-5"></i>
      <span class="text-[10px] font-semibold">Danh Sách</span>
    </button>
    <button onclick="switchTab('customers')" class="flex flex-col items-center space-y-1 text-slate-600 active:text-blue-600 py-1">
      <i data-lucide="users" class="w-5 h-5"></i>
      <span class="text-[10px] font-semibold">Khách</span>
    </button>
    <button onclick="switchTab('reports')" class="flex flex-col items-center space-y-1 text-slate-600 active:text-blue-600 py-1">
      <i data-lucide="bar-chart-3" class="w-5 h-5"></i>
      <span class="text-[10px] font-semibold">Báo Cáo</span>
    </button>
  </div>

  <!-- MAIN APP CONTAINER -->
  <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6 mb-16 md:mb-6">
    
    <!-- Toast Message Container -->
    <div id="toast" class="hidden fixed bottom-20 right-4 md:top-20 md:bottom-auto bg-slate-900 text-white px-4 py-3 rounded-xl shadow-2xl flex items-center space-x-2 z-50 transition-all transform translate-y-2 opacity-0">
      <i data-lucide="info" class="w-5 h-5 text-blue-400"></i>
      <span id="toast-msg" class="text-sm font-medium">Thông báo thành công!</span>
    </div>

    <!-- TAB 1: QUẦY TIẾP NHẬN MÁY -->
    <section id="pane-reception" class="tab-pane space-y-6">
      
      <!-- GRID LAYOUT -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        
        <!-- LEFT PANEL: CUSTOMER & DEVICE INFO -->
        <div class="lg:col-span-7 space-y-6">
          
          <!-- Customer Info -->
          <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center space-x-2">
                <div class="bg-blue-50 text-blue-600 p-1.5 rounded-lg">
                  <i data-lucide="user" class="w-5 h-5"></i>
                </div>
                <h2 class="text-base font-bold text-slate-900">Thông tin khách hàng</h2>
              </div>
              <button onclick="openCustomerSearch()" class="text-xs font-semibold text-blue-600 hover:text-blue-700 flex items-center space-x-1">
                <i data-lucide="search" class="w-3.5 h-3.5"></i>
                <span>Tìm khách cũ</span>
              </button>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Số điện thoại</label>
                <input type="tel" id="cust-phone" oninput="updateLiveReceipt()" placeholder="Nhập SĐT..." class="w-full bg-slate-50 hover:bg-slate-100/50 focus:bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-4 py-2.5 text-sm font-medium outline-none transition-all">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Tên khách hàng</label>
                <input type="text" id="cust-name" oninput="updateLiveReceipt()" placeholder="Tên khách..." class="w-full bg-slate-50 hover:bg-slate-100/50 focus:bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-4 py-2.5 text-sm font-medium outline-none transition-all">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Địa chỉ</label>
                <input type="text" id="cust-address" oninput="updateLiveReceipt()" placeholder="Địa chỉ..." class="w-full bg-slate-50 hover:bg-slate-100/50 focus:bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-4 py-2.5 text-sm font-medium outline-none transition-all">
              </div>
            </div>
          </div>

          <!-- Device Info Section -->
          <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
            <div class="flex items-center space-x-2 mb-4">
              <div class="bg-blue-50 text-blue-600 p-1.5 rounded-lg">
                <i data-lucide="smartphone" class="w-5 h-5"></i>
              </div>
              <h2 class="text-base font-bold text-slate-900">Thông tin thiết bị nhận sửa</h2>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
              <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Tên máy / Model</label>
                <input type="text" id="dev-model" oninput="updateLiveReceipt()" placeholder="Ví dụ: iPhone 12 Pro Max" class="w-full bg-slate-50 hover:bg-slate-100/50 focus:bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-4 py-2.5 text-sm font-medium outline-none transition-all">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Số IMEI / Serial</label>
                <input type="text" id="dev-imei" oninput="updateLiveReceipt()" placeholder="IMEI hoặc Serial máy" class="w-full bg-slate-50 hover:bg-slate-100/50 focus:bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-4 py-2.5 text-sm font-medium outline-none transition-all">
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
              <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Tình trạng máy / Mô tả lỗi</label>
                <textarea id="dev-fault" oninput="updateLiveReceipt()" rows="3" placeholder="Ví dụ: Mất nguồn đột ngột, cắm sạc không báo gì, máy zin chưa bung..." class="w-full bg-slate-50 hover:bg-slate-100/50 focus:bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-4 py-2.5 text-sm font-medium outline-none transition-all resize-none"></textarea>
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Phụ kiện đi kèm / Ghi chú</label>
                <textarea id="dev-notes" oninput="updateLiveReceipt()" rows="3" placeholder="Ví dụ: Trần không phụ kiện, kính sau nứt nhẹ..." class="w-full bg-slate-50 hover:bg-slate-100/50 focus:bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-4 py-2.5 text-sm font-medium outline-none transition-all resize-none"></textarea>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Mật khẩu khóa máy (nếu có)</label>
                <input type="text" id="dev-passcode" oninput="updateLiveReceipt()" placeholder="Mật khẩu màn hình..." class="w-full bg-slate-50 hover:bg-slate-100/50 focus:bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-4 py-2.5 text-sm font-medium outline-none transition-all">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Ngày hẹn trả máy</label>
                <input type="datetime-local" id="dev-deadline" oninput="updateLiveReceipt()" class="w-full bg-slate-50 hover:bg-slate-100/50 focus:bg-white border border-slate-200 focus:border-blue-500 rounded-xl px-4 py-2.5 text-sm font-medium outline-none transition-all">
              </div>
            </div>
          </div>

          <!-- Services Section -->
          <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center space-x-2">
                <div class="bg-blue-50 text-blue-600 p-1.5 rounded-lg">
                  <i data-lucide="wrench" class="w-5 h-5"></i>
                </div>
                <h2 class="text-base font-bold text-slate-900">Chi tiết dịch vụ sửa chữa</h2>
              </div>
              <div class="flex space-x-2">
                <button onclick="addHoldService()" class="text-xs font-bold text-amber-700 hover:text-amber-800 flex items-center space-x-1 bg-amber-50 hover:bg-amber-100 px-3 py-1.5 rounded-lg transition-colors border border-amber-200">
                  <i data-lucide="clock" class="w-3.5 h-3.5"></i>
                  <span>Nhận kiểm tra & Báo sau</span>
                </button>
                <button onclick="triggerF9()" class="text-xs font-bold text-blue-600 hover:text-blue-700 flex items-center space-x-1 bg-blue-50 hover:bg-blue-100 px-3 py-1.5 rounded-lg transition-colors">
                  <i data-lucide="plus" class="w-3.5 h-3.5"></i>
                  <span>Thêm nhanh dịch vụ (F9)</span>
                </button>
              </div>
            </div>

            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-slate-100">
                <thead>
                  <tr class="text-left text-xs font-bold text-slate-400 uppercase tracking-wider">
                    <th class="py-3">Tên dịch vụ / Linh kiện</th>
                    <th class="py-3 text-right">Chi phí (đ)</th>
                    <th class="py-3 text-right">Bảo hành</th>
                    <th class="py-3 text-center">Xóa</th>
                  </tr>
                </thead>
                <tbody id="selected-services-list" class="divide-y divide-slate-100 text-sm">
                  <tr id="empty-service-row">
                    <td colspan="4" class="py-8 text-center text-slate-400 font-medium">Chưa chọn dịch vụ nào. Hãy chọn "Nhận kiểm tra & Báo sau" hoặc "Thêm nhanh dịch vụ (F9)"</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- RIGHT PANEL: CUSTOMER-TEMPLATE LIVE PREVIEW -->
        <div class="lg:col-span-5 space-y-6">
          <div class="bg-white rounded-2xl border border-slate-200 p-1 shadow-md sticky top-24">
            <!-- Mock Document Frame -->
            <div class="bg-white p-5 rounded-xl border border-slate-200 overflow-hidden text-slate-900" style="font-size: 0.85rem">
              
              <!-- Company Header Table -->
              <div class="flex items-start justify-between border-b border-gray-300 pb-4 mb-4">
                <div class="w-1/4 flex flex-col items-center justify-center text-center">
                  <div class="bg-blue-600 text-white p-3 rounded-full mb-1">
                    <i data-lucide="shield-check" class="w-8 h-8"></i>
                  </div>
                  <span class="text-[10px] font-bold text-blue-800 tracking-wider">HP Genuine</span>
                </div>
                <div class="w-3/4 text-right">
                  <span class="text-xs font-bold text-slate-700 tracking-wide uppercase block">LINH KIỆN - PHỤ KIỆN</span>
                  <h2 class="text-2xl font-black text-blue-600 font-receipt">HÙNG PHONG <span class="text-lg text-slate-800">MOBILE</span></h2>
                  <div class="text-[11px] text-slate-600 space-y-0.5 mt-1 font-semibold">
                    <p>* Địa Chỉ: 77-79 Lạc Hồng, P. Rạch Giá, Tỉnh An Giang</p>
                    <p>* Hỗ Trợ Kĩ Thuật: 0907.226.236 - 0766.168.268</p>
                    <p>* Chuyên: Cung cấp linh kiện, phụ kiện sửa chữa, ép kính...</p>
                  </div>
                </div>
              </div>

              <!-- Title -->
              <div class="text-center py-2">
                <h3 class="text-xl font-black text-slate-900 tracking-wide uppercase">BIÊN NHẬN SỬA CHỮA</h3>
              </div>

              <!-- Meta Data -->
              <div class="grid grid-cols-2 gap-4 my-3 text-xs border-b border-gray-200 pb-3">
                <div class="space-y-1">
                  <p class="font-bold text-slate-800">KHÁCH HÀNG: <span id="rec-cust" class="text-blue-600 font-extrabold uppercase">Chưa có tên</span></p>
                  <p class="font-bold text-slate-700">ĐIỆN THOẠI: <span id="rec-phone">Chưa có SĐT</span></p>
                  <p class="text-slate-500 font-medium">Địa chỉ: <span id="rec-address" class="font-bold text-slate-700">--</span></p>
                </div>
                <div class="space-y-1 text-right">
                  <p class="font-semibold text-slate-600">Mã biên nhận: <span id="rec-id" class="font-bold text-slate-900">HP-TEMPORARY</span></p>
                  <p class="text-slate-500">Ngày lập: <span id="rec-created" class="font-bold text-slate-800">--/--/----</span></p>
                </div>
              </div>

              <!-- Main Services Grid -->
              <div class="overflow-x-auto my-3">
                <table class="w-full text-xs print-table">
                  <thead>
                    <tr class="bg-slate-50 text-slate-800">
                      <th class="w-[8%] text-center font-bold">STT</th>
                      <th class="w-[52%] text-center font-bold">TÊN SẢN PHẨM / DỊCH VỤ</th>
                      <th class="w-[10%] text-center font-bold">SL</th>
                      <th class="w-[15%] text-right font-bold">Đơn giá</th>
                      <th class="w-[15%] text-right font-bold">Thành tiền</th>
                    </tr>
                  </thead>
                  <tbody id="rec-services" class="divide-y divide-slate-200">
                    <!-- Dynamic -->
                  </tbody>
                </table>
              </div>

              <!-- Payment Totals -->
              <div class="flex justify-end items-center space-x-2 my-4 text-xs font-bold border-t border-gray-100 pt-3">
                <span class="text-slate-600">Khách hàng thanh toán:</span>
                <span id="rec-total" class="text-base text-blue-600 font-black">0 đ</span>
              </div>

              <!-- Notes Area -->
              <div class="my-3 text-xs">
                <span class="font-bold text-slate-800 underline block mb-1">GHI CHÚ:</span>
                <p id="rec-ghi-chu" class="text-slate-600 italic leading-relaxed whitespace-pre-line bg-slate-50 p-2.5 rounded-xl border border-dashed border-slate-200 min-h-[50px]">Vui lòng nhập thông tin lỗi, mật khẩu máy & phụ kiện kèm theo...</p>
              </div>

              <!-- VietQR Integration inside live preview -->
              <div id="rec-qrcode-box" class="py-3 my-3 bg-blue-50/50 rounded-2xl border border-blue-100/60 text-center flex flex-col items-center justify-center hidden">
                <p class="text-[10px] font-bold text-blue-700 mb-1.5 flex items-center">
                  <i data-lucide="qr-code" class="w-3.5 h-3.5 mr-1 text-blue-600 animate-pulse"></i>
                  Quét mã VietQR Chuyển Khoản Nhanh
                </p>
                <div class="p-1.5 bg-white rounded-xl shadow-sm border border-slate-200">
                  <img id="rec-qrcode-img" src="" alt="VietQR Pay" class="w-24 h-24 object-contain">
                </div>
              </div>

              <!-- Rules & Footers from requested template -->
              <div class="text-[11px] text-slate-500 space-y-1 pt-3 border-t border-dashed border-slate-200 leading-relaxed font-medium">
                <p><strong class="text-slate-800 underline">Lưu ý:</strong> Khi đến nhận máy, vui lòng đem theo <strong>BIÊN NHẬN</strong> này (chỉ trả máy khi có giấy biên nhận).</p>
                <p>- Quý khách vui lòng <strong>giữ lại</strong> vật dụng cá nhân như <em><strong>sim, thẻ nhớ, ghi chú, giấy tờ dán sau máy, ốp lưng...</strong></em></p>
                <p>- HP68 <strong>không chịu trách nhiệm</strong> với các <strong>vật dụng cá nhân sót lại</strong> của máy.</p>
                <p class="font-bold text-slate-700">*** Trường hợp mất giấy biên nhận phải có CCCD hoặc giấy CMND ***</p>
                <p class="text-center font-bold text-slate-700 italic mt-3 block">Hùng Phong cảm ơn Quý Khách Hàng đã tin tưởng và ủng hộ!</p>
                <p class="text-center font-bold text-blue-600 mt-2 block">*** Góp ý, phản ánh liên hệ : 0947.666.368 - 0919.844.833</p>
              </div>

            </div>

            <!-- Invoice Control Actions -->
            <div class="p-4 bg-slate-50 rounded-b-2xl border-t border-slate-200 space-y-3">
              <div class="mb-2">
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">Phương thức giao dịch</label>
                <div class="grid grid-cols-2 gap-2">
                  <button onclick="setPaymentMethod('cash')" id="pay-cash" class="py-2 px-3 text-xs font-semibold rounded-xl border border-blue-600 bg-blue-50/50 text-blue-800 flex items-center justify-center space-x-1.5 transition-all">
                    <i data-lucide="banknote" class="w-3.5 h-3.5"></i>
                    <span>Tiền mặt</span>
                  </button>
                  <button onclick="setPaymentMethod('transfer')" id="pay-transfer" class="py-2 px-3 text-xs font-semibold rounded-xl border border-slate-200 text-slate-600 hover:bg-slate-50 flex items-center justify-center space-x-1.5 transition-all">
                    <i data-lucide="qr-code" class="w-3.5 h-3.5"></i>
                    <span>Chuyển khoản</span>
                  </button>
                </div>
              </div>

              <button onclick="saveAndPrintOrder()" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-4 rounded-xl shadow-lg shadow-blue-500/20 flex items-center justify-center space-x-2 transition-all">
                <i data-lucide="printer" class="w-5 h-5"></i>
                <span>Lưu & In Hóa Đơn (Ctrl + P)</span>
              </button>
