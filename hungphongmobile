        document.getElementById('p-total-container').innerHTML = "<span id='p-total' style='font-size:14px;color:#d97706;font-weight:900;'>CHỜ BÁO GIÁ SAU QUA ĐT</span>";
      } else {
        document.getElementById('p-total-label').innerText = "Khách hàng thanh toán:";
        document.getElementById('p-total-container').innerHTML = `<span id="p-total">${finalTotalValue.toLocaleString('vi-VN')}</span> đ`;
      }

      // Setup QR Code on Real printout if bank transfer selected
      const pQrBox = document.getElementById('p-qr-box');
      const pQrImg = document.getElementById('p-qr-img');
      if (selectedPaymentMethod === 'transfer' && finalTotalValue > 0 && !isHoldQuoteTicket) {
        const cleanedName = encodeURIComponent(name);
