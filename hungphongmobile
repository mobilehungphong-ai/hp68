            <td style="border-right: 1px solid #7a7676; border-bottom: 1px solid #7a7676;">
              <span class="font-bold">${s.name}</span><br>
              <span class="text-[10px] text-slate-500">BH: ${s.warranty}</span>
            </td>
            <td class="text-center font-bold" style="border-right: 1px solid #7a7676; border-bottom: 1px solid #7a7676;">1</td>
            <td class="text-right font-semibold" style="border-right: 1px solid #7a7676; border-bottom: 1px solid #7a7676;">${displayPriceStr}</td>
            <td class="text-right font-bold" style="border-right: 1px solid #7a7676; border-bottom: 1px solid #7a7676;">${displayAmountStr}</td>
          `;
          recSrvContainer.appendChild(row);
        });
      }

      // Cost totals
      if (isHoldQuoteTicket) {
