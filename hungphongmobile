    function addServiceToTicket(serviceId) {
      const match = SERVICES_DATABASE.find(s => s.id === serviceId);
      if (match) {
        // Remove 'Hold-quote' if custom service is selected
        currentTicketServices = currentTicketServices.filter(s => s.price !== -1);

        if (currentTicketServices.some(s => s.name === match.name)) {
          triggerToast("Dịch vụ này đã tồn tại trong danh sách");
          closeModal('service-modal');
          return;
        }

        currentTicketServices.push({
          name: match.name,
          price: match.price,
          warranty: match.warranty
        });

        renderSelectedServicesTable();
        calculateTotals();
        updateLiveReceipt();
        triggerToast(`Đã thêm: ${match.name}`);
        closeModal('service-modal');
      }
    }

    // Add Special Hold-Quote service (For unknown issues, pan checking)
    function addHoldService() {
      currentTicketServices = []; // Clear other services since this is diagnostic hold
      currentTicketServices.push({
        name: "Nhận máy kiểm tra & Báo giá sau",
