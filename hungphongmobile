    // Save & print receipt flow
    function saveAndPrintOrder() {
      const phone = document.getElementById('cust-phone').value.trim();
      const name = document.getElementById('cust-name').value.trim();
      const model = document.getElementById('dev-model').value.trim();
      const fault = document.getElementById('dev-fault').value.trim();
      const passcode = document.getElementById('dev-passcode').value.trim();
      const notes = document.getElementById('dev-notes').value.trim();

      if (!phone || !name || !model || !fault) {
        showCustomAlert("Còn thiếu thông tin", "Yêu cầu bắt buộc để tạo hóa đơn: Số điện thoại, Tên khách hàng, Model máy và Tình trạng lỗi của máy.", "warning");
        return;
      }

      if (currentTicketServices.length === 0) {
        showCustomAlert("Chưa có dịch vụ", "Vui lòng chọn ít nhất một dịch vụ sửa chữa hoặc nhấn 'Nhận máy kiểm tra & Báo sau'.", "warning");
        return;
      }

      const orderId = "HP-" + (10000 + ORDERS.length + 5);
      const deadlineVal = document.getElementById('dev-deadline').value;
      const formattedDeadline = deadlineVal ? new Date(deadlineVal).toLocaleString('vi-VN') : "Thỏa thuận sau";
      const rightNow = new Date().toLocaleString('vi-VN');

      // Build & Push Order
      const newOrder = {
        id: orderId,
        customer: {
          name: name,
          phone: phone,
          address: document.getElementById('cust-address').value.trim() || "Rạch Giá"
        },
        device: {
          model: model,
          imei: document.getElementById('dev-imei').value.trim() || "Chưa cung cấp",
          fault: fault,
          passcode: passcode || "Không cài",
          notes: notes || "Không kèm phụ kiện",
          deadline: deadlineVal || "Thỏa thuận"
        },
        services: [...currentTicketServices],
        subtotal: subtotalValue,
        discount: calculatedDiscountValue,
        promo: promoAmount,
        total: finalTotalValue,
        paymentMethod: selectedPaymentMethod,
        status: isHoldQuoteTicket ? "Đang kiểm tra / Chờ báo giá" : "Mới nhận",
        createdAt: new Date().toISOString()
      };

      ORDERS.unshift(newOrder);

      // Map details to actual printed template matching the user's layout
      document.getElementById('p-order-id').innerText = orderId;
      document.getElementById('p-cust-name').innerText = name;
      document.getElementById('p-p-cust-phone').innerText = phone;
      document.getElementById('p-cust-address').innerText = newOrder.customer.address;
      document.getElementById('p-created-on').innerText = rightNow;

      // Handwritten style note line on printout
      let finalNoteLine = `Model máy: ${model} | IMEI: ${newOrder.device.imei} | Lỗi máy: ${fault}`;
      if (passcode) finalNoteLine += ` | Mật khẩu khóa: ${passcode}`;
      if (notes) finalNoteLine += ` | Phụ kiện: ${notes}`;
      if (deadlineVal) finalNoteLine += ` | Hẹn giao: ${formattedDeadline}`;
      document.getElementById('p-ghi-chu-text').innerText = finalNoteLine;

      // Populate services print list in print table style
      const pSrvList = document.getElementById('p-services-list');
      pSrvList.innerHTML = "";
      currentTicketServices.forEach((s, idx) => {
        const displayPriceText = s.price === -1 ? "Báo giá sau" : `${s.price.toLocaleString('vi-VN')}đ`;
        const displayAmountText = s.price === -1 ? "Chờ kiểm tra" : `${s.price.toLocaleString('vi-VN')}đ`;

        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td style="text-align: center; border-right: 1px solid #7a7676; border-bottom: 1px solid #7a7676; font-weight: bold;">${idx + 1}</td>
          <td style="border-right: 1px solid #7a7676; border-bottom: 1px solid #7a7676; padding: 6px;">
            <strong style="font-size: 13px;">${s.name}</strong><br>
            <span style="font-size: 10px; color: #555;">Bảo hành: ${s.warranty}</span>
          </td>
          <td style="text-align: center; border-right: 1px solid #7a7676; border-bottom: 1px solid #7a7676; font-weight: bold;">1</td>
          <td style="text-align: right; border-right: 1px solid #7a7676; border-bottom: 1px solid #7a7676; font-weight: bold; padding: 6px;">${displayPriceText}</td>
          <td style="text-align: right; border-right: 1px solid #7a7676; border-bottom: 1px solid #7a7676; font-weight: bold; padding: 6px;">${displayAmountText}</td>
        `;
        pSrvList.appendChild(tr);
      });

      // Handle Printed Total label
