      calculateTotals();
      updateLiveReceipt();
      triggerToast("Đã chọn chế độ Nhận kiểm tra & Báo sau");
    }

    function addCustomService() {
      const name = document.getElementById('custom-service-name').value.trim();
      const priceVal = document.getElementById('custom-service-price').value;

      if (!name || !priceVal) {
        showCustomAlert("Lỗi thông tin", "Vui lòng nhập đầy đủ tên dịch vụ và giá chi phí sửa chữa.", "warning");
