    function removeServiceFromTicket(index) {
      currentTicketServices.splice(index, 1);
      renderSelectedServicesTable();
      calculateTotals();
      updateLiveReceipt();
    }

    // State totals calculation
    let subtotalValue = 0;
    let finalTotalValue = 0;
    let calculatedDiscountValue = 0;
    let isHoldQuoteTicket = false;

    function calculateTotals() {
      isHoldQuoteTicket = currentTicketServices.some(s => s.price === -1);
      
      if (isHoldQuoteTicket) {
        subtotalValue = 0;
        calculatedDiscountValue = 0;
        finalTotalValue = -1; // -1 represents hold/unknown quote
      } else {
        subtotalValue = currentTicketServices.reduce((sum, s) => sum + s.price, 0);
        calculatedDiscountValue = discountCash;
        if (discountPercent > 0) {
          calculatedDiscountValue = Math.round(subtotalValue * (discountPercent / 100));
        }
        finalTotalValue = Math.max(0, subtotalValue - calculatedDiscountValue - promoAmount);
      }
    }

