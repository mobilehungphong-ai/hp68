          <td class="py-4 px-4 text-center">
            <div class="flex items-center justify-center space-x-1.5">
              <button onclick="triggerStatusUpdate('${o.id}')" title="Cập nhật trạng thái" class="bg-blue-50 hover:bg-blue-100 text-blue-600 p-2 rounded-xl transition-colors">
                <i data-lucide="refresh-cw" class="w-4 h-4"></i>
              </button>
              <button onclick="reprintOrderDirect('${o.id}')" title="In lại hóa đơn" class="bg-slate-100 hover:bg-slate-200 text-slate-600 p-2 rounded-xl transition-colors">
                <i data-lucide="printer" class="w-4 h-4"></i>
              </button>
            </div>
          </td>
        `;
        tbody.appendChild(tr);
      });
      lucide.createIcons();
    }

    function filterStatus(status) {
      activeFilterStatus = status;
      
      document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.className = "filter-btn px-4 py-2 text-xs font-bold rounded-xl bg-slate-100 text-slate-600 hover:bg-slate-200 transition-all";
      });

      const ids = {
        all: 'btn-filter-all',
        'Mới nhận': 'btn-filter-received',
        'Đang kiểm tra / Chờ báo giá': 'btn-filter-pending-quote',
        'Đang sửa': 'btn-filter-fixing',
        'Đã sửa xong': 'btn-filter-done',
        'Đã giao': 'btn-filter-delivered'
      };

      document.getElementById(ids[status]).className = "filter-btn px-4 py-2 text-xs font-bold rounded-xl bg-blue-600 text-white shadow-md shadow-blue-500/15 transition-all";
      renderOrdersList();
    }

    function filterOrdersTable() {
      const q = document.getElementById('order-search-input').value.toLowerCase();
      const tbody = document.getElementById('orders-table-body');
      const rows = tbody.getElementsByTagName('tr');

      for (let i = 0; i < rows.length; i++) {
        const text = rows[i].textContent.toLowerCase();
        if (text.includes(q)) {
          rows[i].classList.remove('hidden');
        } else {
          rows[i].classList.add('hidden');
        }
      }
    }

    function reprintOrderDirect(orderId) {
      const order = ORDERS.find(o => o.id === orderId);
      if (!order) return;

      document.getElementById('p-order-id').innerText = order.id;
      document.getElementById('p-cust-name').innerText = order.customer.name;
      document.getElementById('p-p-cust-phone').innerText = order.customer.phone;
      document.getElementById('p-cust-address').innerText = order.customer.address;
      document.getElementById('p-created-on').innerText = new Date(order.createdAt).toLocaleString('vi-VN');

      let printNotes = `Model máy: ${order.device.model} | IMEI: ${order.device.imei} | Lỗi: ${order.device.fault}`;
      if (order.device.passcode) printNotes += ` | Mật khẩu: ${order.device.passcode}`;
      if (order.device.notes) printNotes += ` | Phụ kiện: ${order.device.notes}`;
      if (order.device.deadline) printNotes += ` | Hẹn giao: ${new Date(order.device.deadline).toLocaleString('vi-VN')}`;
      document.getElementById('p-ghi-chu-text').innerText = printNotes;

      const pSrvList = document.getElementById('p-services-list');
      pSrvList.innerHTML = "";
      
      const hasHoldService = order.services.some(s => s.price === -1);

      order.services.forEach((s, idx) => {
        const displayPriceText = s.price === -1 ? "Báo giá sau" : `${s.price.toLocaleString('vi-VN')}đ`;
        const displayAmountText = s.price === -1 ? "Chờ kiểm tra" : `${s.price.toLocaleString('vi-VN')}đ`;

        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td style="text-align: center; border-right: 1px solid #7a7676; border-bottom: 1px solid #7a7676; font-weight: bold;">${idx + 1}</td>
          <td style="border-right: 1px solid #7a7676; border-bottom: 1px solid #7a7676; padding: 6px;">
            <strong style="font-size: 13px;">${s.name}</strong><br>
            <span style="font-size: 10px; color: #555;">Bảo hành: ${s.warranty}</span>
          </td>
          <td style="text-align: center; border-right: 1px solid #7a7676; border-bottom: 1px solid #7a7676; font-weight: bold;">1</td>
          <td style="text-align: right; border-right: 1px solid #7a7676; border-bottom: 1px solid #7a7676; font-weight: bold; padding: 6px;">${displayPriceText}</td>
          <td style="text-align: right; border-right: 1px solid #7a7676; border-bottom: 1px solid #7a7676; font-weight: bold; padding: 6px;">${displayAmountText}</td>
        `;
        pSrvList.appendChild(tr);
      });

      if (hasHoldService) {
        document.getElementById('p-total-label').innerText = "Trạng thái thanh toán:";
        document.getElementById('p-total-container').innerHTML = "<span id='p-total' style='font-size:14px;color:#d97706;font-weight:900;'>CHỜ BÁO GIÁ SAU QUA ĐT</span>";
      } else {
        document.getElementById('p-total-label').innerText = "Khách hàng thanh toán:";
        document.getElementById('p-total-container').innerHTML = `<span id="p-total">${order.total.toLocaleString('vi-VN')}</span> đ`;
      }

      const pQrBox = document.getElementById('p-qr-box');
      const pQrImg = document.getElementById('p-qr-img');
      if (order.paymentMethod === 'transfer' && order.total > 0 && !hasHoldService) {
        const cleanedName = encodeURIComponent(order.customer.name);
        pQrImg.src = `https://img.vietqr.io/image/mbbank-0907226236-compact2.png?amount=${order.total}&addInfo=HUNG%20PHONG%20${cleanedName}&accountName=HUNG%20PHONG%20MOBILE`;
        pQrBox.style.display = 'block';
      } else {
        pQrBox.style.display = 'none';
      }

      window.print();
    }

    function triggerStatusUpdate(orderId) {
      document.getElementById('status-target-order-id').value = orderId;
      
      const order = ORDERS.find(o => o.id === orderId);
      const priceBox = document.getElementById('status-price-update-box');
      
      // If the order has "Nhận kiểm tra & báo sau", show price update panel
      if (order && order.services.some(s => s.price === -1)) {
        priceBox.classList.remove('hidden');
        document.getElementById('status-new-price').value = "";
      } else {
        priceBox.classList.add('hidden');
      }

      openModal('status-modal');
    }

    function updateOrderStatus(newStatus) {
      const id = document.getElementById('status-target-order-id').value;
      const order = ORDERS.find(o => o.id === id);
      if (order) {
        const hasHoldService = order.services.some(s => s.price === -1);
        
        // If price is updated
        if (hasHoldService) {
          const newPriceInput = document.getElementById('status-new-price').value;
          if (newPriceInput && parseInt(newPriceInput) >= 0) {
            const parsedPrice = parseInt(newPriceInput);
            // Replace diagnostic item with real service fee item
            order.services = [{
              name: "Sửa chữa khắc phục lỗi nguồn / IC",
              price: parsedPrice,
              warranty: "3 Tháng"
            }];
            order.subtotal = parsedPrice;
            order.total = parsedPrice;
            triggerToast(`Đã cập nhật báo giá thành công: ${parsedPrice.toLocaleString('vi-VN')}đ`);
          }
        }

        order.status = newStatus;
        triggerToast(`Đã đổi trạng thái đơn ${id} thành: ${newStatus}`);
        closeModal('status-modal');
        renderOrdersList();
      }
    }

    // Customers view tab
    function renderCustomersList() {
      const grid = document.getElementById('customers-list-grid');
      grid.innerHTML = "";

      const uniqueCusts = {};
      ORDERS.forEach(o => {
        if (!uniqueCusts[o.customer.phone]) {
          uniqueCusts[o.customer.phone] = {
            name: o.customer.name,
            phone: o.customer.phone,
            address: o.customer.address,
            count: 1,
            totalSpend: o.total === -1 ? 0 : o.total
          };
        } else {
          uniqueCusts[o.customer.phone].count++;
          if (o.total !== -1) {
            uniqueCusts[o.customer.phone].totalSpend += o.total;
          }
        }
      });

      const list = Object.values(uniqueCusts);

      list.forEach(c => {
        const card = document.createElement('div');
        card.className = "bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow cursor-pointer";
        card.setAttribute('onclick', `selectCustomerFromList('${c.phone}', '${c.name}', '${c.address}')`);
        card.innerHTML = `
          <div>
            <div class="flex items-center justify-between mb-3">
              <span class="bg-blue-50 text-blue-800 text-[10px] font-extrabold py-1 px-2 rounded-lg">Khách Hàng Thân Thiết</span>
              <span class="text-xs text-slate-400 font-bold">${c.count} lượt sửa chữa</span>
            </div>
            <h4 class="font-extrabold text-slate-800 text-base">${c.name}</h4>
            <p class="text-sm text-slate-500 font-semibold mt-1 flex items-center">
              <i data-lucide="phone" class="w-3.5 h-3.5 mr-1.5 text-slate-400"></i>
              <span>${c.phone}</span>
            </p>
            <p class="text-xs text-slate-400 font-semibold mt-1 flex items-center">
              <i data-lucide="map-pin" class="w-3.5 h-3.5 mr-1.5 text-slate-400"></i>
              <span>${c.address}</span>
            </p>
          </div>
          <div class="border-t border-slate-100 pt-3 mt-4 flex justify-between items-center text-xs">
            <span class="text-slate-400 font-bold">Tổng doanh thu:</span>
            <span class="font-black text-slate-900">${c.totalSpend.toLocaleString('vi-VN')}đ</span>
          </div>
        `;
        grid.appendChild(card);
      });
      lucide.createIcons();
    }

    function selectCustomerFromList(phone, name, address) {
      document.getElementById('cust-phone').value = phone;
      document.getElementById('cust-name').value = name;
      document.getElementById('cust-address').value = address;
      
      switchTab('reception');
      updateLiveReceipt();
      triggerToast(`Đã tải thông tin khách hàng: ${name}`);
    }

    function filterCustomers() {
      const q = document.getElementById('cust-search-input').value.toLowerCase();
      const grid = document.getElementById('customers-list-grid');
      const cards = grid.children;

      for (let i = 0; i < cards.length; i++) {
        const text = cards[i].textContent.toLowerCase();
        if (text.includes(q)) {
          cards[i].classList.remove('hidden');
        } else {
          cards[i].classList.add('hidden');
        }
      }
    }

    function openCustomerSearch() {
      switchTab('customers');
      triggerToast("Bạn có thể tìm kiếm khách hàng cũ tại đây");
    }

    function updateReportsMetrics() {
      const totalRevenue = ORDERS.filter(o => o.status === 'Đã giao' && o.total !== -1).reduce((sum, o) => sum + o.total, 0);
      const fixing = ORDERS.filter(o => o.status === 'Đang sửa' || o.status === 'Đang kiểm tra / Chờ báo giá').length;
      const done = ORDERS.filter(o => o.status === 'Đã sửa xong').length;
      const delivered = ORDERS.filter(o => o.status === 'Đã giao').length;

      document.getElementById('report-revenue').innerText = totalRevenue.toLocaleString('vi-VN') + "đ";
      document.getElementById('report-fixing-count').innerText = fixing + " Đơn";
      document.getElementById('report-done-count').innerText = done + " Đơn";
      document.getElementById('report-completed-count').innerText = delivered + " Máy";
    }

    function showGiftModal() {
      showCustomAlert("Chương trình Đổi Quà", "Chức năng tích điểm đổi quà hiện chưa được kích hoạt cho chiến dịch này.", "info");
    }

    function showSettings() {
      showCustomAlert("Thiết lập hệ thống", "Dùng để thiết lập kết nối máy in nhiệt Bluetooth/USB, cấu hình API Ngân hàng và phân quyền thợ kỹ thuật.", "info");
    }

    function showChangePrice() {
      showCustomAlert("Đổi giá bán", "Hãy nhấn Thêm nhanh dịch vụ (F9) -> nhập Tên dịch vụ & Giá bán khác bên ngoài danh mục tự do.", "info");
    }

    function showAllActions() {
      showCustomAlert("Tất cả thao tác", "Hệ thống hỗ trợ phím tắt tiện ích:\n- F9: Thêm nhanh dịch vụ\n- F6: Thiết lập chiết khấu\n- F8: Áp dụng khuyến mại\n- F11: Làm mới dọn sạch quầy", "info");
    }
  </script>
</body>
</html>
